#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export HERMES_HOME="${HERMES_HOME:-$REPO_ROOT/.local/hermes-users/dev-jc}"
ENV_FILE="${HERMES_ENV_FILE:-$HERMES_HOME/.env}"

if [[ ! -f "$ENV_FILE" ]]; then
  cat >&2 <<EOF
Missing Hermes local env file:
  $ENV_FILE

Create it from docs/secretary-local-proof.md or copy the local proof template.
EOF
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

HERMES_BIN="${HERMES_BIN:-$REPO_ROOT/.venv/bin/hermes}"
MIRROR_BIN="${MIRROR_BIN:-$REPO_ROOT/.venv/bin/hermes-postgres-mirror}"
PYTHON_BIN="${PYTHON_BIN:-$REPO_ROOT/.venv/bin/python}"

if [[ ! -x "$HERMES_BIN" ]]; then
  HERMES_BIN="hermes"
fi

if [[ ! -x "$MIRROR_BIN" ]]; then
  MIRROR_BIN="hermes-postgres-mirror"
fi

if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python3"
fi

sync_runtime_config_from_env() {
  "$PYTHON_BIN" - <<'PY'
import os
from pathlib import Path

import yaml

home = Path(os.environ["HERMES_HOME"])
path = home / "config.yaml"

try:
    data = yaml.safe_load(path.read_text(encoding="utf-8")) if path.exists() else {}
except Exception:
    data = {}

if not isinstance(data, dict):
    data = {}

model_cfg = data.get("model")
if not isinstance(model_cfg, dict):
    model_cfg = {}

provider = (
    os.getenv("HERMES_INFERENCE_PROVIDER", "").strip()
    or os.getenv("HERMES_MODEL_PROVIDER", "").strip()
)
model = (
    os.getenv("HERMES_INFERENCE_MODEL", "").strip()
    or os.getenv("HERMES_MODEL", "").strip()
)
base_url = (
    os.getenv("HERMES_INFERENCE_BASE_URL", "").strip()
    or os.getenv("BEDROCK_BASE_URL", "").strip()
)

if provider:
    model_cfg["provider"] = provider
if model:
    model_cfg["default"] = model
if base_url:
    model_cfg["base_url"] = base_url.rstrip("/")
if model_cfg:
    data["model"] = model_cfg

bedrock_cfg = data.get("bedrock")
if not isinstance(bedrock_cfg, dict):
    bedrock_cfg = {}

bedrock_region = (
    os.getenv("HERMES_BEDROCK_REGION", "").strip()
    or os.getenv("BEDROCK_REGION", "").strip()
    or os.getenv("AWS_REGION", "").strip()
    or os.getenv("AWS_DEFAULT_REGION", "").strip()
)
if bedrock_region:
    bedrock_cfg["region"] = bedrock_region
if bedrock_cfg:
    data["bedrock"] = bedrock_cfg

home.mkdir(parents=True, exist_ok=True)
path.write_text(yaml.safe_dump(data, sort_keys=False), encoding="utf-8")
print(path)
PY
}

command_name="${1:-gateway}"
case "$command_name" in
  gateway)
    sync_runtime_config_from_env >/dev/null
    exec "$HERMES_BIN" gateway
    ;;
  sync-config)
    sync_runtime_config_from_env
    ;;
  migrate|backfill|status)
    exec "$MIRROR_BIN" "$command_name"
    ;;
  smoke)
    sync_runtime_config_from_env >/dev/null
    export API_SERVER_URL="${API_SERVER_URL:-http://${API_SERVER_HOST:-127.0.0.1}:${API_SERVER_PORT:-8642}}"
    export HERMES_SESSION_KEY="${HERMES_SESSION_KEY:-secretary:user:dev-jc}"
    exec "$PYTHON_BIN" "$REPO_ROOT/scripts/secretary_api_smoke.py"
    ;;
  cli)
    shift
    sync_runtime_config_from_env >/dev/null
    exec "$HERMES_BIN" "$@"
    ;;
  *)
    exec "$HERMES_BIN" "$@"
    ;;
esac
